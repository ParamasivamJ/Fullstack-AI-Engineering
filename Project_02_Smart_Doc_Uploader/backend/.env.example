# Project 02 — .env Template
# Copy this to .env and fill in your values

APP_NAME=Smart Document Uploader
APP_ENV=development
DEBUG=true

# PostgreSQL with pgvector
# Run: docker run -d --name pgvector -e POSTGRES_DB=docuploader -e POSTGRES_USER=appuser -e POSTGRES_PASSWORD=apppass -p 5432:5432 pgvector/pgvector:pg16
DATABASE_URL=postgresql+asyncpg://appuser:apppass@localhost:5432/docuploader
SYNC_DATABASE_URL=postgresql://appuser:apppass@localhost:5432/docuploader

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=.pdf,.docx,.txt

# Embedding model (downloaded automatically on first use)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP_SENTENCES=2

# Search defaults
DEFAULT_TOP_K=5
DEFAULT_SCORE_THRESHOLD=0.3
